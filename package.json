{
  "name": "omni",
  "version": "0.1.0",
  "private": true,
  "description": "OmniContext multi-session agentic workspace supervisor",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev -w @omni/desktop",
    "start": "npm run start -w @omni/desktop"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
