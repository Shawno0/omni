{
  "name": "@omni/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Omni desktop supervisor",
  "author": "Omni",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npm run prepare:runtime && tsc -p tsconfig.json",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "typecheck": "npm run prepare:runtime && tsc -p tsconfig.json --noEmit",
    "prepare:runtime": "node ./scripts/ensureCodeServer.mjs",
    "update:code-server": "node ./scripts/ensureCodeServer.mjs --force",
    "doctor": "node ./scripts/doctor.mjs",
    "dev": "npm run prepare:runtime && npm run build && electron .",
    "postinstall": "electron-rebuild -w node-pty",
    "start": "npm run prepare:runtime && electron .",
    "package:win": "npm run prepare:runtime && npm run build && electron-builder --config electron-builder.yml --win",
    "package:linux": "npm run prepare:runtime && npm run build && electron-builder --config electron-builder.yml --linux",
    "package:mac": "npm run prepare:runtime && npm run build && electron-builder --config electron-builder.yml --mac",
    "protocol:register": "node ./scripts/registerProtocol.mjs",
    "protocol:validate": "node ./scripts/validateProtocol.mjs"
  },
  "dependencies": {
    "@omni/shared": "*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "pidtree": "^0.6.0",
    "pidusage": "^3.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.10.2",
    "@types/pidusage": "^2.0.5",
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3"
  }
}
